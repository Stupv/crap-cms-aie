{{#if breadcrumbs}}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {{#each breadcrumbs}}
    <li>
      {{#if this.url}}
      <a href="{{this.url}}" hx-get="{{this.url}}" hx-target="body" hx-push-url="true">{{this.label}}</a>
      {{else}}
      <span>{{this.label}}</span>
      {{/if}}
    </li>
    {{/each}}
  </ol>
</nav>
{{/if}}
