<fieldset class="form__array" data-field-type="array" data-field-name="{{name}}">
  <legend>
    {{label}}
    {{#if required}}<span class="required">*</span>{{/if}}
  </legend>

  <div class="form__array-rows" id="array-rows-{{name}}">
    {{#each rows}}
    <div class="form__array-row" data-row-index="{{this.index}}">
      <div class="form__array-row-fields">
        {{#each this.sub_fields}}
        <div class="form__array-sub-field">
          <label>{{this.name}}</label>
          <input
            type="text"
            name="{{this.field_name_indexed}}"
            value="{{this.value}}"
          />
        </div>
        {{/each}}
      </div>
      <button type="button" class="btn btn--sm btn--danger" onclick="removeArrayRow(this)">Remove</button>
    </div>
    {{/each}}
  </div>

  <template id="array-template-{{name}}">
    <div class="form__array-row" data-row-index="__INDEX__">
      <div class="form__array-row-fields">
        {{#each sub_fields}}
        <div class="form__array-sub-field">
          <label>{{this.name}}</label>
          <input
            type="text"
            name="{{../name}}[__INDEX__][{{this.name}}]"
            value=""
          />
        </div>
        {{/each}}
      </div>
      <button type="button" class="btn btn--sm btn--danger" onclick="removeArrayRow(this)">Remove</button>
    </div>
  </template>

  <button type="button" class="btn btn--sm btn--secondary" onclick="addArrayRow('{{name}}')">Add Row</button>

  {{#if error}}<p class="form__error">{{error}}</p>{{/if}}
  {{#if description}}<p class="form__help">{{description}}</p>{{/if}}
</fieldset>
