<div class="form__collapsible{{#if collapsed}} form__collapsible--collapsed{{/if}}"
     data-collapsible data-group-name="{{name}}" data-field-name="{{name}}">
  <button type="button" class="form__collapsible-toggle" onclick="toggleGroup(this)">
    <span class="form__group-chevron material-symbols-outlined">expand_more</span>
    {{label}}
  </button>
  <div class="form__collapsible-body">
    {{#each sub_fields}}
    <div class="form__field{{#if (eq condition_visible false)}} form__field--hidden{{/if}}"
      {{#if condition_json}}data-condition='{{{json condition_json}}}'{{/if}}
      {{#if condition_ref}}data-condition-ref="{{condition_ref}}"{{/if}}
      data-field-name="{{name}}">
      {{{render_field this}}}
    </div>
    {{/each}}
  </div>
  {{#if error}}<p class="form__error">{{error}}</p>{{/if}}
  {{#if description}}<p class="form__help">{{description}}</p>{{/if}}
</div>
