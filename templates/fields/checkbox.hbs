<div class="form__checkbox">
  <input
    type="checkbox"
    id="field-{{name}}"
    name="{{name}}"
    {{#if checked}}checked{{/if}}
  />
  <label for="field-{{name}}">{{label}}</label>
</div>
{{#if error}}<p class="form__error">{{error}}</p>{{/if}}
{{#if description}}<p class="form__help">{{description}}</p>{{/if}}
